t = int(input())

for i in range(t):
    n = int(input())
    x = list(map(int, input().split()))
    
    left = 0
    right = n - 1
    
    found = True
    for k in range(1, n + 1):
        if x[left] == k:
            left += 1
        elif x[right] == k:
            right -= 1
        else:
            found = False
            break
            
    if found:
        print("YES")
    else:
        print("NO")
