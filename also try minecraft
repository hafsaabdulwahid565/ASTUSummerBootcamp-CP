c,t= map(int,input().split())
x=list(map(int,input().split()))
for j in range(t):  
     damage=0
     p,q=map(int,input().split())
     if p<q:
         for i in range(p-1,q-1):
             if x[i]>x[i+1]:
                 damage+=x[i]-x[i+1]
     else:
         for i in range(p-1,q-1,-1):
             if x[i]>x[i-1]:
                 damage+=x[i]-x[i-1]

                         
     print(damage)

        



